{
  "name": "index-n2",
  "version": "0.1.0",
  "description": "Local viewer for fieldtheory-cli bookmarks. Reads from ~/.ft-bookmarks/.",
  "keywords": [
    "fieldtheory-cli",
    "fieldtheory",
    "bookmarks",
    "twitter-bookmarks",
    "twitter",
    "x-bookmarks",
    "bookmark-viewer",
    "gallery",
    "gui"
  ],
  "author": {
    "name": "Refraction",
    "url": "https://refraction.studio",
    "email": "contact@refraction.studio"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/refractionweb/index-n2.git"
  },
  "bugs": {
    "url": "https://github.com/refractionweb/index-n2/issues"
  },
  "homepage": "https://github.com/refractionweb/index-n2#readme",
  "type": "module",
  "main": "server.js",
  "bin": {
    "index-n2": "server.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/",
    "server.js",
    "colorize.js",
    "dedup.js",
    "thumbnails.js",
    "atomic-write.js"
  ],
  "scripts": {
    "start": "node server.js",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "open": "^11.0.0",
    "quantize": "^1.0.2",
    "sharp": "^0.34.5",
    "sql.js-fts5": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@fontsource-variable/inter": "^5.2.8",
    "@remixicon/react": "^4.9.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.3.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1"
  }
}
